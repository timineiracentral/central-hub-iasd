# Web3Forms — https://web3forms.com
# Crie uma access key no painel e use localmente em .env.local (não commitado).
# No GitHub: Settings → Secrets → Actions → VITE_WEB3FORMS_ACCESS_KEY (para o deploy no Pages).
VITE_WEB3FORMS_ACCESS_KEY=

# ImgBB — https://api.imgbb.com/ (upload gratuito de imagens; o link entra no e-mail do Web3Forms)
# No GitHub: secret VITE_IMGBB_API_KEY
VITE_IMGBB_API_KEY=
